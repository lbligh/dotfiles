{
    "[cpp]": {
        "editor.quickSuggestions": {
            "comments": "on",
            "other": "on",
            "strings": "on"
        },
        "editor.semanticHighlighting.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.wordBasedSuggestions": "off"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[django-html]": {
        "djlint.enableLinting": true,
        "djlint.profile": "django"
    },
    "[html][handlebars][hbs][mustache][jinja][jinja-html][nj][njk][nunjucks][twig]": {
        "djlint.enableLinting": true,
        "editor.defaultFormatter": "monosans.djlint",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true,
        "editor.linkedEditing": true,
        "editor.tabSize": 2
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    },
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop",
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 80,
        "editor.wrappingIndent": "same"
    },
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": true,
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports.ruff": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.formatOnType": true
    },
    "[shellscript]": {
        "editor.defaultColorDecorators": "never",
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "files.eol": "\n"
    },
    "bootstrapIntelliSense": {
        "bsVersion": "5.3.0",
        "enable": true
    },
    "cmake.configureOnOpen": false,
    "cmake.generator": "Unix Makefiles",
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "debug.onTaskErrors": "abort",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.maxComputationTime": 0,
    // djlint
    "djlint.customBlocks": ["timezone"],
    "djlint.formatCss": true,
    "djlint.formatJs": true,
    "djlint.ignore": ["H006", "H017", "H021", "H023", "H030", "H031"],
    "djlint.indentCss": 2,
    "djlint.indentJs": 2,
    // editor
    "editor.acceptSuggestionOnEnter": "off",
    "editor.accessibilitySupport": "off",
    "editor.detectIndentation": false,
    "editor.fontFamily": "'Fira Code', Menlo, Monaco, 'Cosurier New', monospace, 'SF Mono'",
    "editor.fontLigatures": true,
    "editor.fontSize": 13.5,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.stickyScroll.defaultModel": "indentationModel",
    "editor.stickyScroll.maxLineCount": 8,
    "editor.suggest.showWords": false,
    // explorer
    "explorer.compactFolders": true,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    // files
    "files.associations": {
        "*.html": "html"
    },
    "files.exclude": {
        "**/.DS_Store": false,
        "**/.git": false
    },
    "files.trimTrailingWhitespace": true,
    // git
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.ignoreRebaseWarning": true,
    // gitlens
    "gitlens.advanced.messages": {
        "suppressLineUncommittedWarning": true
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4o",
    "gitlens.graph.minimap.additionalTypes": [
        "localBranches",
        "pullRequests",
        "remoteBranches",
        "stashes",
        "tags"
    ],
    "gitlens.graph.minimap.dataType": "lines",
    "gitlens.views.commitDetails.files.layout": "tree",
    "gitlens.views.scm.grouped.views": {
        "branches": true,
        "commits": true,
        "contributors": true,
        "launchpad": false,
        "remotes": true,
        "repositories": false,
        "searchAndCompare": true,
        "stashes": true,
        "tags": true,
        "worktrees": true
    },
    "html.format.templating": true,
    "keyboard.touchbar.enabled": false,
    // latex
    "latex-utilities.countWord.format": "${wordsBody} Words",
    "latex-workshop.bibtex-format.tab": "4 spaces",
    "latex-workshop.latex.tools": [
        {
            "args": [
                "%DOC%",
                "-file-line-error",
                "-interaction=nonstopmode",
                "-outdir=%OUTDIR%",
                "-pdf",
                "-shell-escape",
                "-synctex=1"
            ],
            "command": "latexmk",
            "env": {},
            "name": "latexmk"
        },
        {
            "args": [
                "%DOC%",
                "-file-line-error",
                "-interaction=nonstopmode",
                "-lualatex",
                "-outdir=%OUTDIR%",
                "-synctex=1"
            ],
            "command": "latexmk",
            "env": {},
            "name": "lualatexmk"
        },
        {
            "args": [
                "%DOC%",
                "-file-line-error",
                "-interaction=nonstopmode",
                "-outdir=%OUTDIR%",
                "-synctex=1",
                "-xelatex"
            ],
            "command": "latexmk",
            "env": {},
            "name": "xelatexmk"
        },
        {
            "args": ["%DOC%"],
            "command": "latexmk",
            "env": {},
            "name": "latexmk_rconly"
        },
        {
            "args": [
                "%DOC%",
                "-file-line-error",
                "-interaction=nonstopmode",
                "-synctex=1"
            ],
            "command": "pdflatex",
            "env": {},
            "name": "pdflatex"
        },
        {
            "args": ["%DOCFILE%"],
            "command": "bibtex",
            "env": {},
            "name": "bibtex"
        },
        {
            "args": [
                "-e",
                "knitr::opts_knit$set(concordance = TRUE); knitr::knit('%DOCFILE_EXT%')"
            ],
            "command": "Rscript",
            "env": {},
            "name": "rnw2tex"
        },
        {
            "args": [
                "-e",
                "using Weave; weave(\"%DOC_EXT%\", doctype=\"tex\")"
            ],
            "command": "julia",
            "env": {},
            "name": "jnw2tex"
        },
        {
            "args": [
                "-e",
                "using Weave; weave(\"%DOC_EXT%\", doctype=\"texminted\")"
            ],
            "command": "julia",
            "env": {},
            "name": "jnw2texminted"
        },
        {
            "args": ["%DOC_EXT%", "-f", "tex"],
            "command": "pweave",
            "env": {},
            "name": "pnw2tex"
        },
        {
            "args": ["%DOC_EXT%", "-f", "texminted"],
            "command": "pweave",
            "env": {},
            "name": "pnw2texminted"
        },
        {
            "args": ["%DOC%.tex", "--keep-logs", "--synctex"],
            "command": "tectonic",
            "env": {},
            "name": "tectonic"
        }
    ],
    "latex-workshop.view.pdf.viewer": "tab",
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.codeActionsOnSave": {
        "notebook.source.organizeImports.ruff": "explicit"
    },
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "notebook.formatOnCellExecution": true,
    "notebook.formatOnSave.enabled": true,
    "outline.collapseItems": "alwaysCollapse",
    "prettier.tabWidth": 4,
    // pylint
    "pylint.importStrategy": "fromEnvironment",
    "python.analysis.autoFormatStrings": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.REPL.enableREPLSmartSend": false,
    // Raspberry
    "remote.SSH.connectTimeout": 30,
    "ruff.lint.ignore": [],
    "scm.diffDecorationsIgnoreTrimWhitespace": "inherit",
    "security.workspace.trust.untrustedFiles": "open",
    "shellformat.path": "/usr/local/bin/shfmt",
    // terminal
    "terminal.external.osxExec": "iTerm.app",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.env.osx": {},
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.initialHint": false,
    "todohighlight.include": [
        "**/*.c",
        "**/*.css",
        "**/*.h",
        "**/*.html",
        "**/*.js",
        "**/*.jsx",
        "**/*.md",
        "**/*.mdown",
        "**/*.php",
        "**/*.rb",
        "**/*.scss",
        "**/*.tex",
        "**/*.ts",
        "**/*.tsx",
        "**/*.txt"
    ],
    "window.title": "${activeEditorMedium}${separator}${rootName}${separator}${profileName}${dirty}",
    "workbench.colorTheme": "Dark Modern",
    "workbench.editor.useModal": "off",
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.ipynb": "jupyter-notebook",
        "*.svg": "default"
    },
    "workbench.settings.alwaysShowAdvancedSettings": true
}
